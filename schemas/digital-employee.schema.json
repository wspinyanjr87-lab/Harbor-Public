{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grace.local/schemas/digital-employee.schema.json",
  "title": "Digital Employee",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "jobTitle", "department", "managerId", "mission", "responsibilities", "permissions", "triggers", "sops", "approvalPolicy", "metrics", "escalationPolicy", "status", "version", "audit"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "name": {"type": "string", "minLength": 1},
    "jobTitle": {"type": "string", "minLength": 1},
    "department": {"type": "string", "minLength": 1},
    "managerId": {"type": ["string", "null"]},
    "mission": {"type": "string", "minLength": 1},
    "responsibilities": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "permissions": {"type": "object", "required": ["tools", "dataScopes", "prohibitedActions"], "properties": {"tools": {"type": "array", "items": {"type": "string"}}, "dataScopes": {"type": "array", "items": {"type": "string"}}, "prohibitedActions": {"type": "array", "items": {"type": "string"}}}},
    "triggers": {"type": "array", "items": {"type": "object", "required": ["type"], "properties": {"type": {"enum": ["manual", "schedule", "event", "queue"]}, "value": {"type": "string"}}}},
    "sops": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "approvalPolicy": {"type": "object", "required": ["level", "requiresApprovalFor"], "properties": {"level": {"enum": ["observe", "draft", "execute_limited", "execute", "admin"]}, "requiresApprovalFor": {"type": "array", "items": {"type": "string"}}}},
    "metrics": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["name"], "properties": {"name": {"type": "string"}, "target": {}, "direction": {"enum": ["higher", "lower", "range"]}}}},
    "escalationPolicy": {"type": "object", "required": ["destination", "conditions"], "properties": {"destination": {"type": "string"}, "conditions": {"type": "array", "minItems": 1, "items": {"type": "string"}}}},
    "status": {"enum": ["draft", "active", "paused", "blocked", "retired"]},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "audit": {"type": "object", "required": ["createdBy", "createdAt", "updatedAt"], "properties": {"createdBy": {"type": "string"}, "createdAt": {"type": "string", "format": "date-time"}, "updatedAt": {"type": "string", "format": "date-time"}}}
  }
}
