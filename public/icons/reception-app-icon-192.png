<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" role="img" aria-labelledby="title desc">
  <title id="title">Harbor Reception Desk</title>
  <desc id="desc">A gold reception bell with an anchor emblem on a deep harbor green background.</desc>
  <defs>
    <linearGradient id="bg" x1="70" y1="36" x2="442" y2="478" gradientUnits="userSpaceOnUse">
      <stop stop-color="#21494A"/>
      <stop offset="1" stop-color="#102F30"/>
    </linearGradient>
    <linearGradient id="gold" x1="160" y1="138" x2="354" y2="392" gradientUnits="userSpaceOnUse">
      <stop stop-color="#F2D49B"/>
