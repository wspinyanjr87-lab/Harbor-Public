      <stop offset="1" stop-color="#B97834"/>
    </linearGradient>
    <linearGradient id="cream" x1="150" y1="302" x2="356" y2="430" gradientUnits="userSpaceOnUse">
      <stop stop-color="#FFF9EC"/>
      <stop offset="1" stop-color="#EEDFC6"/>
    </linearGradient>
    <filter id="shadow" x="-25%" y="-25%" width="150%" height="170%">
      <feDropShadow dx="0" dy="18" stdDeviation="16" flood-color="#071E1F" flood-opacity=".42"/>
    </filter>
  </defs>
